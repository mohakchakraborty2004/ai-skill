// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String         @id @default(cuid())
  email       String         @unique
  name        String?
  password    String // Store hashed password
  // Relations
  resume      ResumeData?
  github      GithubProfile?
  evaluations Evaluation[]

  sessions      Session[]

  createdAt DateTime @default(now())
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  // Relation back to the User
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResumeData {
  id         String   @id @default(cuid())
  userId     String   @unique
  skills     String[] // Store extracted skills as JSON array: ["Next.js", "TypeScript", "Prisma"]
  experience Int // Years of experience extracted by Gemini

  user User @relation(fields: [userId], references: [id])
}

model GithubProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  username     String   @unique
  topLanguages String[] // Store detected languages as JSON array: ["TypeScript", "Python"]
  totalCommits Int // Commits in the last 90 days
  totalStars   Int // Sum of stars across top repos

  user User @relation(fields: [userId], references: [id])
}

model Evaluation {
  id                String @id @default(cuid())
  userId            String @unique
  score             Int
  baselineScore     Int
  feedback          String
  disputesRemaining Int    @default(5) // 5-Chamber Rule: max 5 disputes per user

  disputes    DisputeLog[]
  peerRatings PeerRating[]

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// The new model for the crowdsourced ground truth
model PeerRating {
  id           String @id @default(cuid())
  evaluationId String

  humanScore   Int    // The 0-100 score the peer suggested
  reviewerRole String // e.g., "Senior Software Engineer"
  remarks      String @db.Text // The justification they typed out

  // Backpropagation: loss = humanScore - systemScore, AI proposes new weights
  systemScoreAtTime        Int? // Snapshot of system score when review was submitted
  proposedSkillWeight      Float?
  proposedDensityWeight    Float?
  proposedComplexityWeight Float?
  weightUpdateApplied      Boolean @default(false)

  createdAt  DateTime   @default(now())
  evaluation Evaluation @relation(fields: [evaluationId], references: [id])
}

model DisputeLog {
  id           String @id @default(cuid())
  evaluationId String
  userClaim    String // What the user argued
  aiReasoning  String // Why the AI accepted or rejected it
  scoreDelta   Int

  // Backpropagation: AI-proposed ideal weights when dispute is won
  proposedSkillWeight      Float?
  proposedDensityWeight    Float?
  proposedComplexityWeight Float?
  weightUpdateApplied      Boolean @default(false)

  createdAt  DateTime   @default(now())
  evaluation Evaluation @relation(fields: [evaluationId], references: [id])
}

model SystemWeights {
  id                    String   @id @default("global_weights")
  skillWeight           Float    @default(0.50)
  densityWeight         Float    @default(0.30)
  complexityWeight      Float    @default(0.20)
  totalUpdates          Int      @default(0)  // How many times the weights have been updated
  updatedAt             DateTime @updatedAt
}
